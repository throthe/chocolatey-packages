<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>infranview</id>
    <version>4.75</version>
    <title>IrfanView</title>
    <authors>Irfan Skiljan</authors>
    <owners>Thomas Rothe (throthe)</owners>
    <packageSourceUrl>https://github.com/jmcker/ChocolateyPackages/tree/main/published/infranview</packageSourceUrl>
    <projectUrl>https://www.irfanview.com/</projectUrl>
    <licenseUrl>https://www.irfanview.com/eula.htm</licenseUrl>
    <iconUrl>https://rawcdn.githack.com/throthe/chocolatey-packages/bc833be59d7eeef2ac845ca105fc1241fef9a747/icons/IrfanView_Logo2.png</iconUrl>
    <wikiUrl>https://en.wikipedia.org/wiki/IrfanView</wikiUrl>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <tags>infranview infran image jpeg bmp png gif conversion</tags>
    <summary>Fast and compact image viewer and editor</summary>
    <description>IrfanView is a free image viewer and editor for Microsoft Windows. It supports a wide range of image formats and is known for its speed and ease of use. Features include image viewing, editing, batch processing, and conversion.</description>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
